# Environment Configuration Template
# Copy this to .env and fill in your values

# Application
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# MLflow Tracking
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=support-system

# Vector Database
CHROMA_DB_PATH=./chroma_db
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Graph Database (Neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Feature Store
FEAST_REPO_PATH=./feature_repo

# Model Configuration
CATEGORIZATION_MODEL=xgboost
CONFIDENCE_THRESHOLD=0.85
RAG_TOP_K=5

# Data Paths
TICKET_DATA_PATH=./support_tickets.json
TRAIN_DATA_PATH=./data/splits/train.parquet
VAL_DATA_PATH=./data/splits/val.parquet
TEST_DATA_PATH=./data/splits/test.parquet
